<Window x:Class="GeorgiaERP.Desktop.Views.Warehouse.ShippingOrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Shipping Order" Width="700" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="660">
            <TextBlock Text="Create Shipping Order" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Warehouse *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                                      SelectedValuePath="Id" SelectedValue="{Binding WarehouseId}" Padding="8,6" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Order Type" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox SelectedItem="{Binding OrderType}" Padding="8,6">
                                <ComboBoxItem Content="SalesOrder" />
                                <ComboBoxItem Content="Transfer" />
                                <ComboBoxItem Content="Return" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Carrier" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Carrier, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Expected Ship Date" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding ExpectedShipDate}" Padding="8,6" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Shipping Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding ShippingAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Notes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="40" Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Lines" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button Content="+ Add Line" Style="{StaticResource SecondaryButton}" Command="{Binding AddLineCommand}" HorizontalAlignment="Right" />
                    </DockPanel>

                    <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding Lines}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" Margin="0,0,0,12" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Product" Width="*"
                                                     ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     DisplayMemberPath="Name" SelectedValuePath="Id"
                                                     SelectedValueBinding="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Ordered Qty" Binding="{Binding OrderedQty, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel" Margin="0,0,8,0" />
                        <Button Content="Create" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
