<UserControl x:Class="GeorgiaERP.Desktop.Views.Warehouse.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Warehouse" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ComboBox ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedWarehouse}" Width="200" Padding="8,6" Margin="0,0,8,0" />
                <ComboBox SelectedValue="{Binding StatusFilter}" Width="140" Padding="8,6" Margin="0,0,8,0">
                    <ComboBoxItem Content="All Statuses" IsSelected="True" />
                    <ComboBoxItem Content="Expected" />
                    <ComboBoxItem Content="InProgress" />
                    <ComboBoxItem Content="Completed" />
                    <ComboBoxItem Content="Draft" />
                    <ComboBoxItem Content="Picking" />
                    <ComboBoxItem Content="Packed" />
                    <ComboBoxItem Content="Shipped" />
                </ComboBox>
                <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" />
            </StackPanel>
        </DockPanel>

        <!-- Tabs -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Receiving" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Receiving}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Receiving" />
            <RadioButton Content="Shipping" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Shipping}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Shipping" />
            <RadioButton Content="Locations" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Locations}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Locations" />
        </StackPanel>

        <!-- Error -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorMessage}"
                   Foreground="Red" Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Pagination -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="Total: " /><Run Text="{Binding TotalCount}" FontWeight="SemiBold" />
            </TextBlock>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Previous" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousPageCommand}" Margin="0,0,8,0" />
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Page " /><Run Text="{Binding CurrentPage}" /><Run Text=" of " /><Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Content="Next" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextPageCommand}" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>

        <!-- Receiving Orders -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Receiving}">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                <Button Content="Start Receiving" Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartReceivingCommand}" Margin="0,0,8,0" />
                <Button Content="Complete" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CompleteReceivingCommand}" Margin="0,0,8,0" />
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelReceivingCommand}" />
            </StackPanel>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding ReceivingOrders}"
                          SelectedItem="{Binding SelectedReceiving}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RCV #" Binding="{Binding ReceivingNumber}" Width="160" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
                        <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedDate, StringFormat=d}" Width="100" />
                        <DataGridTextColumn Header="Received" Binding="{Binding ReceivedAt, StringFormat=g}" Width="140" />
                        <DataGridTextColumn Header="Lines" Binding="{Binding Lines.Count}" Width="60" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Shipping Orders -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Shipping}">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left">
                <Button Content="Start Picking" Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartPickingCommand}" Margin="0,0,8,0" />
                <Button Content="Pack" Style="{StaticResource PrimaryButton}"
                        Command="{Binding PackOrderCommand}" Margin="0,0,8,0" />
                <Button Content="Ship" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ShipOrderCommand}" Margin="0,0,8,0" />
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelShippingCommand}" />
            </StackPanel>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding ShippingOrders}"
                          SelectedItem="{Binding SelectedShipping}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SHP #" Binding="{Binding ShippingNumber}" Width="160" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="110" />
                        <DataGridTextColumn Header="Carrier" Binding="{Binding Carrier}" Width="100" />
                        <DataGridTextColumn Header="Tracking" Binding="{Binding TrackingNumber}" Width="130" />
                        <DataGridTextColumn Header="Shipped" Binding="{Binding ShippedAt, StringFormat=g}" Width="140" />
                        <DataGridTextColumn Header="Lines" Binding="{Binding Lines.Count}" Width="60" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Locations -->
        <Border Style="{StaticResource Card}" Padding="0"
                Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Locations}">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Locations}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding LocationType}" Width="80" />
                    <DataGridTextColumn Header="Capacity" Binding="{Binding MaxCapacity}" Width="80" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
