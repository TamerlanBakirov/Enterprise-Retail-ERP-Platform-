<UserControl x:Class="GeorgiaERP.Desktop.Views.Admin.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Audit Log" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
        </DockPanel>

        <!-- Filters -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Entity Type" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Width="160"
                             Text="{Binding EntityTypeFilter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Entity Id" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Width="220"
                             Text="{Binding EntityIdFilter, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="From" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding DateFrom}" Width="130" />
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="To" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding DateTo}" Width="130" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Search" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SearchCommand}" />
                    <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearFiltersCommand}" Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Pagination footer -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="‹ Prev" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousPageCommand}" />
                <TextBlock VerticalAlignment="Center" Margin="12,0"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Page " /><Run Text="{Binding CurrentPage}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                    <Run Text="  •  " /><Run Text="{Binding TotalCount}" /><Run Text=" entries" />
                </TextBlock>
                <Button Content="Next ›" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextPageCommand}" />
            </StackPanel>
        </DockPanel>

        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding AuditLogs}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat=g}" Width="150" />
                    <DataGridTextColumn Header="Entity Type" Binding="{Binding EntityType}" Width="160" />
                    <DataGridTextColumn Header="Entity Id" Binding="{Binding EntityId}" Width="220" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100" />
                    <DataGridTextColumn Header="Changed Properties" Binding="{Binding ChangedProperties}" Width="*" />
                    <DataGridTextColumn Header="User" Binding="{Binding UserId}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
