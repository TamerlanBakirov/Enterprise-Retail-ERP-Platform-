<UserControl x:Class="GeorgiaERP.Desktop.Views.Admin.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="User Management" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox Style="{StaticResource ModernTextBox}" Width="250"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Search" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}" Margin="8,0,0,0" />
                <Button Content="+ Add User" Style="{StaticResource PrimaryButton}"
                        Click="OnAddUser" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <TextBlock DockPanel.Dock="Bottom" Margin="0,12" HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="{Binding TotalCount}" /><Run Text=" users" />
        </TextBlock>

        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120" />
                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="120" />
                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=d}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
