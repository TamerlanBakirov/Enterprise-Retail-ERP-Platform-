<Window x:Class="GeorgiaERP.Desktop.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dashboard="clr-namespace:GeorgiaERP.Desktop.Views.Dashboard"
        xmlns:pos="clr-namespace:GeorgiaERP.Desktop.Views.POS"
        xmlns:products="clr-namespace:GeorgiaERP.Desktop.Views.Products"
        xmlns:inventory="clr-namespace:GeorgiaERP.Desktop.Views.Inventory"
        xmlns:customers="clr-namespace:GeorgiaERP.Desktop.Views.Customers"
        xmlns:procurement="clr-namespace:GeorgiaERP.Desktop.Views.Procurement"
        xmlns:finance="clr-namespace:GeorgiaERP.Desktop.Views.Finance"
        xmlns:reports="clr-namespace:GeorgiaERP.Desktop.Views.Reports"
        xmlns:settings="clr-namespace:GeorgiaERP.Desktop.Views.Settings"
        xmlns:warehouse="clr-namespace:GeorgiaERP.Desktop.Views.Warehouse"
        xmlns:admin="clr-namespace:GeorgiaERP.Desktop.Views.Admin"
        xmlns:pricing="clr-namespace:GeorgiaERP.Desktop.Views.Pricing"
        xmlns:compliance="clr-namespace:GeorgiaERP.Desktop.Views.Compliance"
        Title="Georgia ERP"
        Width="1400" Height="850"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Update banner -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#FFF3CD" Padding="12,8"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Download"
                        Style="{StaticResource PrimaryButton}" Padding="16,6"
                        Command="{Binding DownloadUpdateCommand}" Margin="8,0,0,0" />
                <Button DockPanel.Dock="Right" Content="X"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="#856404" FontWeight="Bold"
                        Command="{Binding DismissUpdateCommand}" Margin="8,0,0,0" />
                <TextBlock VerticalAlignment="Center" Foreground="#856404">
                    <Run Text="A new version (" /><Run Text="{Binding UpdateVersion}" FontWeight="Bold" /><Run Text=") is available." />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Offline indicator -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#FEE2E2" Padding="12,6"
                Visibility="{Binding OfflinePendingCount, Converter={StaticResource NullToCollapsedConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Retry"
                        Style="{StaticResource SecondaryButton}" Padding="16,4"
                        Command="{Binding RetryOfflineCommand}" Margin="8,0,0,0" />
                <TextBlock VerticalAlignment="Center" Foreground="#991B1B">
                    <Run Text="{Binding OfflinePendingCount}" FontWeight="Bold" />
                    <Run Text=" pending offline operation(s)" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <DockPanel>
                <!-- Logo area -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <TextBlock Text="Georgia ERP"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="{Binding UserDisplayName}"
                                   FontSize="12"
                                   Foreground="#94A3B8"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding UserRole}"
                                   FontSize="11"
                                   Foreground="#64748B" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="#334155" Margin="16,0" />

                <!-- Logout button at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="8,12">
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Foreground="#94A3B8"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Padding="16,8" />
                </Border>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Dashboard"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Dashboard}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Dashboard" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="POS / Sales"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=POS}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="POS" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Products"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Products}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Products" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Inventory"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Inventory}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Inventory" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Warehouse"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Warehouse}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Warehouse" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Customers"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Customers}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Customers" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Procurement"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Procurement}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Procurement" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Pricing"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Pricing}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Pricing" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Finance"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Finance}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Finance" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="RS.GE / Compliance"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Compliance}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Compliance" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Reports"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Reports}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Reports" />

                        <Border Height="1" Background="#334155" Margin="16,12" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Users"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Users}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Users" />

                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="Settings"
                                     IsChecked="{Binding CurrentView, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Settings}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="Settings" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource ContentBgBrush}">
            <Grid>
                <dashboard:DashboardView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Dashboard}" />
                <pos:PosView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=POS}" />
                <products:ProductsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Products}" />
                <inventory:InventoryView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Inventory}" />
                <warehouse:WarehouseView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Warehouse}" />
                <customers:CustomersView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Customers}" />
                <procurement:ProcurementView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Procurement}" />
                <pricing:PricingView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Pricing}" />
                <finance:FinanceView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Finance}" />
                <compliance:ComplianceView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Compliance}" />
                <reports:ReportsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Reports}" />
                <admin:UsersView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Users}" />
                <settings:SettingsView Visibility="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Settings}" />
            </Grid>
        </Border>
    </Grid>
</Window>
