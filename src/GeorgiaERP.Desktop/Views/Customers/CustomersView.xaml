<UserControl x:Class="GeorgiaERP.Desktop.Views.Customers.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Customers" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox Style="{StaticResource ModernTextBox}" Width="250"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Search" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}" Margin="8,0,0,0" />
                <Button Content="+ Add Customer" Style="{StaticResource PrimaryButton}"
                        Click="OnAddCustomer" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Border DockPanel.Dock="Bottom" Padding="0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Page " /><Run Text="{Binding CurrentPage}" />
                    <Run Text=" of " /><Run Text="{Binding TotalPages}" />
                    <Run Text=" (" /><Run Text="{Binding TotalCount}" /><Run Text=" customers)" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding FirstName}" Width="120" />
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="120" />
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="130" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                        <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="150" />
                        <DataGridTextColumn Header="Loyalty Card" Binding="{Binding LoyaltyCardNumber}" Width="120" />
                        <DataGridTextColumn Header="Tier" Binding="{Binding LoyaltyTier}" Width="70" />
                        <DataGridTextColumn Header="Points" Binding="{Binding LoyaltyPoints}" Width="70" />
                        <DataGridTextColumn Header="Visits" Binding="{Binding TotalVisits}" Width="60" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Loyalty history side panel for the selected customer -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12" Margin="12,0,0,0" Width="360"
                    Visibility="{Binding SelectedCustomer, Converter={StaticResource NullToCollapsedConverter}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Loyalty History" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                    <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                        <Run Text="{Binding SelectedCustomer.FirstName, Mode=OneWay}" />
                        <Run Text="{Binding SelectedCustomer.LastName, Mode=OneWay}" />
                        <Run Text=" — " /><Run Text="{Binding SelectedCustomer.LoyaltyPoints, Mode=OneWay}" /><Run Text=" pts" />
                    </TextBlock>
                    <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding LoyaltyHistory}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=g}" Width="120" />
                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="70" />
                            <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="60" />
                            <DataGridTextColumn Header="Balance" Binding="{Binding BalanceAfter}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
