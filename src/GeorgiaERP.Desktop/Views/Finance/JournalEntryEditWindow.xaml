<Window x:Class="GeorgiaERP.Desktop.Views.Finance.JournalEntryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Journal Entry" Width="700" Height="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="660">
            <TextBlock Text="Add Journal Entry" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Description *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Date *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding EntryDate}" Padding="8,6" />
                        </StackPanel>
                    </Grid>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Lines" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+ Add Line" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddLineCommand}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Style="{StaticResource ModernDataGrid}"
                              ItemsSource="{Binding Lines}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              Margin="0,0,0,12" MaxHeight="250">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Account" Width="*"
                                                     ItemsSource="{Binding DataContext.Accounts, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     DisplayMemberPath="Name" SelectedValuePath="Id"
                                                     SelectedValueBinding="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Debit" Binding="{Binding DebitAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            <DataGridTextColumn Header="Credit" Binding="{Binding CreditAmount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Click="OnCancel" Margin="0,0,8,0" />
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
