<Window x:Class="GeorgiaERP.Desktop.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Georgia ERP — Login"
        Width="450" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">

    <Grid>
        <Border Style="{StaticResource Card}" Margin="40,60" VerticalAlignment="Top">
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="Georgia ERP"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="Enterprise Retail Platform"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30" />

                <!-- Server URL -->
                <TextBlock Text="Server" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="ServerUrlBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="UsernameBox"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16" />

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,24" />

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                <!-- Login Button -->
                <Button Content="Login"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnLoginClick"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        HorizontalAlignment="Stretch" />

                <!-- Loading -->
                <ProgressBar IsIndeterminate="True"
                             Height="3" Margin="0,12,0,0"
                             Foreground="{StaticResource PrimaryBrush}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
