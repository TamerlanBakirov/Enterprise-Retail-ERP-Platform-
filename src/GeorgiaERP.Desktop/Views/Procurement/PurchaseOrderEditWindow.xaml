<Window x:Class="GeorgiaERP.Desktop.Views.Procurement.PurchaseOrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Purchase Order" Width="750" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Create Purchase Order" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Supplier *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="Name"
                                      SelectedValuePath="Id" SelectedValue="{Binding SupplierId}"
                                      Padding="8,6" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Warehouse *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Warehouses}" DisplayMemberPath="Name"
                                      SelectedValuePath="Id" SelectedValue="{Binding WarehouseId}"
                                      Padding="8,6" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Notes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="50" Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Order Lines" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button Content="+ Add Line" Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddLineCommand}" HorizontalAlignment="Right" />
                    </DockPanel>

                    <DataGrid Style="{StaticResource ModernDataGrid}"
                              ItemsSource="{Binding Lines}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}"
                              Margin="0,0,0,12" MaxHeight="250">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Product" Width="*"
                                                     ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     DisplayMemberPath="Name" SelectedValuePath="Id"
                                                     SelectedValueBinding="{Binding ProductId, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Click="OnCancel" Margin="0,0,8,0" />
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
