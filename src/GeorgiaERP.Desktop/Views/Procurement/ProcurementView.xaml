<UserControl x:Class="GeorgiaERP.Desktop.Views.Procurement.ProcurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Procurement" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <Button Content="Refresh" Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoadCommand}" HorizontalAlignment="Right" />
        </DockPanel>

        <!-- Tabs -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Suppliers" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Suppliers}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Suppliers" />
            <RadioButton Content="Purchase Orders" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=PurchaseOrders}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="PurchaseOrders" />
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Suppliers -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Suppliers}">
            <Button DockPanel.Dock="Top" Content="+ Add Supplier" Style="{StaticResource PrimaryButton}"
                    Click="OnAddSupplier" HorizontalAlignment="Left" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding Suppliers}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Tax ID" Binding="{Binding TaxId}" Width="120" />
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="130" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180" />
                        <DataGridTextColumn Header="Payment Terms" Binding="{Binding PaymentTermDays}" Width="100" />
                        <DataGridCheckBoxColumn Header="VAT" Binding="{Binding IsVatPayer}" Width="50" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Purchase Orders -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=PurchaseOrders}">
            <Button DockPanel.Dock="Top" Content="+ Create Purchase Order" Style="{StaticResource PrimaryButton}"
                    Click="OnAddPurchaseOrder" HorizontalAlignment="Left" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding PurchaseOrders}"
                          SelectedItem="{Binding SelectedPurchaseOrder}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Order #" Binding="{Binding PoNumber}" Width="130" />
                        <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="VAT" Binding="{Binding VatTotal, StringFormat=N2}" Width="80" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=d}" Width="100" />
                        <DataGridTemplateColumn Header="Action" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Approve" Style="{StaticResource SecondaryButton}" Padding="8,2"
                                            Command="{Binding DataContext.ApprovePurchaseOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Border>

                <!-- Selected purchase order line detail -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12" Margin="12,0,0,0" Width="420"
                        Visibility="{Binding SelectedPurchaseOrder, Converter={StaticResource NullToCollapsedConverter}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Order Lines" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                            <Run Text="{Binding SelectedPurchaseOrder.PoNumber, Mode=OneWay}" />
                            <Run Text=" — " /><Run Text="{Binding SelectedPurchaseOrder.Total, Mode=OneWay, StringFormat=N2}" /><Run Text=" GEL" />
                        </TextBlock>
                        <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding SelectedPoLines}"
                                  ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                  RowStyle="{StaticResource ModernDataGridRow}" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="Ordered" Binding="{Binding OrderedQty, StringFormat=N2}" Width="70" />
                                <DataGridTextColumn Header="Recv" Binding="{Binding ReceivedQty, StringFormat=N2}" Width="60" />
                                <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="70" />
                                <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </DockPanel>
</UserControl>
