<Window x:Class="GeorgiaERP.Desktop.Views.Procurement.SupplierEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Supplier" Width="480" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="420">
            <TextBlock Text="Add Supplier" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Code *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Name *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Name (Georgian)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding NameKa, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Tax ID" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding TaxId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Phone" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Payment Terms (days)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding PaymentTermDays, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <CheckBox Grid.Column="2" Content="VAT Payer" IsChecked="{Binding IsVatPayer}"
                                  VerticalAlignment="Bottom" Margin="0,0,0,4" />
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Click="OnCancel" Margin="0,0,8,0" />
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
