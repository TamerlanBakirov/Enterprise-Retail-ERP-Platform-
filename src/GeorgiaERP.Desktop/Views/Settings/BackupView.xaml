<UserControl x:Class="GeorgiaERP.Desktop.Views.Settings.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Database Backups" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
        </DockPanel>

        <!-- Create backup -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Backup Type" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <ComboBox Width="160" ItemsSource="{Binding BackupTypes}"
                              SelectedItem="{Binding SelectedBackupType}" />
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Notes (optional)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Width="320"
                             Text="{Binding BackupNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <Button Content="Create Backup" Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom"
                        Command="{Binding CreateBackupCommand}"
                        IsEnabled="{Binding IsCreating, Converter={StaticResource InverseBoolConverter}}" />
            </StackPanel>
        </Border>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8"
                   Foreground="{StaticResource DangerBrush}"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <!-- Pagination footer -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="‹ Prev" Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviousPageCommand}" />
                <TextBlock VerticalAlignment="Center" Margin="12,0"
                           Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Page " /><Run Text="{Binding CurrentPage}" /><Run Text=" / " /><Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Content="Next ›" Style="{StaticResource SecondaryButton}"
                        Command="{Binding NextPageCommand}" />
            </StackPanel>
        </DockPanel>

        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding Backups}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="Size (KB)" Binding="{Binding FileSizeBytes, StringFormat={}{0:N0}}" Width="100" />
                    <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat=g}" Width="140" />
                    <DataGridTextColumn Header="Completed" Binding="{Binding CompletedAt, StringFormat=g}" Width="140" />
                    <DataGridTextColumn Header="By" Binding="{Binding InitiatedByUserName}" Width="120" />
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Restore" Style="{StaticResource SecondaryButton}"
                                            Click="OnRestore" Padding="10,4" />
                                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                                            Click="OnDelete" Padding="10,4" Margin="6,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
