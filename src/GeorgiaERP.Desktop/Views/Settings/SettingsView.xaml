<UserControl x:Class="GeorgiaERP.Desktop.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Server URL" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" />

                    <TextBlock Text="Language" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <ComboBox SelectedValue="{Binding Language}" Padding="8,6" Margin="0,0,0,24">
                        <ComboBoxItem Content="Georgian" Tag="ka" />
                        <ComboBoxItem Content="English" Tag="en" />
                    </ComboBox>

                    <Button Content="Save Settings"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Left" />

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,12,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
