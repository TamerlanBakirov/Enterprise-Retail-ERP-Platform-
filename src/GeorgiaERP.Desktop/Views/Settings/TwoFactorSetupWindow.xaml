<Window x:Class="GeorgiaERP.Desktop.Views.Settings.TwoFactorSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Two-Factor Authentication" Width="440" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="400">
            <TextBlock Text="Two-Factor Authentication" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Setup mode: Begin button -->
                    <Button Content="Begin 2FA Setup" Style="{StaticResource PrimaryButton}"
                            Command="{Binding BeginSetupCommand}" Margin="0,0,0,12"
                            Visibility="{Binding SetupStarted, Converter={StaticResource InverseBoolConverter}}" />

                    <!-- Show shared key after setup begins -->
                    <StackPanel Visibility="{Binding SetupStarted, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Enter this key in your authenticator app:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding SharedKey, Mode=OneWay}"
                                 IsReadOnly="True" FontFamily="Consolas" FontSize="14" Margin="0,0,0,16" />
                    </StackPanel>

                    <TextBlock Text="Verification Code" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="6" FontFamily="Consolas" FontSize="16" Margin="0,0,0,16" />

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,8" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,8" Visibility="{Binding SuccessMessage, Converter={StaticResource NullToCollapsedConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Disable 2FA" Style="{StaticResource SecondaryButton}"
                                Command="{Binding DisableCommand}" Margin="0,0,8,0" />
                        <Button Content="Confirm Setup" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmSetupCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="Close" Style="{StaticResource SecondaryButton}"
                    Click="OnClose" HorizontalAlignment="Right" Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
