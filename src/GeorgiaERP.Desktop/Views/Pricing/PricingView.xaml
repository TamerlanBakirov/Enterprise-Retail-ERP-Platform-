<UserControl x:Class="GeorgiaERP.Desktop.Views.Pricing.PricingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Pricing" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <Button Content="Refresh" Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoadCommand}" HorizontalAlignment="Right" />
        </DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Price Lists" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=PriceLists}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="PriceLists" />
            <RadioButton Content="Promotions" Style="{StaticResource NavButton}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Promotions}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Promotions" />
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3"
                     Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Price Lists -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=PriceLists}">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Add Price List" Style="{StaticResource PrimaryButton}" Click="OnAddPriceList" Margin="0,0,8,0" />
                <Button Content="+ Set Price" Style="{StaticResource SecondaryButton}" Click="OnSetPrice" />
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <DataGrid Style="{StaticResource ModernDataGrid}"
                              ItemsSource="{Binding PriceLists}" SelectedItem="{Binding SelectedPriceList}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding PriceType}" Width="80" />
                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="70" />
                            <DataGridTextColumn Header="Valid From" Binding="{Binding ValidFrom, StringFormat=d}" Width="100" />
                            <DataGridTextColumn Header="Valid To" Binding="{Binding ValidTo, StringFormat=d}" Width="100" />
                            <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="60" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <TextBlock Grid.Row="1" Text="Price List Items" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,4" />

                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <DataGrid Style="{StaticResource ModernDataGrid}"
                              ItemsSource="{Binding PriceListItems}"
                              ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=N2}" Width="120" />
                            <DataGridTextColumn Header="Min Qty" Binding="{Binding MinQty, StringFormat=N0}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </DockPanel>

        <!-- Promotions -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Promotions}">
            <Button DockPanel.Dock="Top" Content="+ Add Promotion" Style="{StaticResource PrimaryButton}"
                    Click="OnAddPromotion" HorizontalAlignment="Left" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ItemsSource="{Binding Promotions}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding PromotionType}" Width="100" />
                        <DataGridTextColumn Header="Discount" Binding="{Binding DiscountValue}" Width="80" />
                        <DataGridTextColumn Header="Valid From" Binding="{Binding ValidFrom, StringFormat=d}" Width="100" />
                        <DataGridTextColumn Header="Valid To" Binding="{Binding ValidTo, StringFormat=d}" Width="100" />
                        <DataGridTextColumn Header="Uses" Binding="{Binding CurrentUses}" Width="60" />
                        <DataGridTextColumn Header="Max" Binding="{Binding MaxUses}" Width="60" />
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>
    </DockPanel>
</UserControl>
