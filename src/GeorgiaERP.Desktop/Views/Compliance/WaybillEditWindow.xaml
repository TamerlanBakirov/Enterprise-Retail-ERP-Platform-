<Window x:Class="GeorgiaERP.Desktop.Views.Compliance.WaybillEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Waybill" Width="750" Height="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ContentBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Create Waybill" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Waybill Type" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox SelectedValuePath="Content" SelectedValue="{Binding WaybillType}" Padding="8,6">
                                <ComboBoxItem Content="Inner" />
                                <ComboBoxItem Content="Transport" />
                                <ComboBoxItem Content="Return" />
                                <ComboBoxItem Content="Subcontract" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Transport Type" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox SelectedValuePath="Content" SelectedValue="{Binding TransportType}" Padding="8,6">
                                <ComboBoxItem Content="Auto" />
                                <ComboBoxItem Content="Railway" />
                                <ComboBoxItem Content="Aviation" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Vehicle #" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding VehicleNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Buyer TIN *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding BuyerTin, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Lookup" Style="{StaticResource SecondaryButton}"
                                Command="{Binding LookupBuyerCommand}" VerticalAlignment="Bottom" Margin="4,0,0,0" Padding="8,6" />
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Buyer Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding BuyerName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Seller TIN *" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding SellerTin, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Driver TIN" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding DriverTin, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding EndAddress, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Goods" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button Content="+ Add Item" Style="{StaticResource SecondaryButton}" Command="{Binding AddLineCommand}" HorizontalAlignment="Right" />
                    </DockPanel>

                    <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding GoodsLines}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                              RowStyle="{StaticResource ModernDataGridRow}" Margin="0,0,0,12" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            <DataGridTextColumn Header="Unit ID" Binding="{Binding UnitId, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            <DataGridTextColumn Header="Barcode" Binding="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel" Margin="0,0,8,0" />
                        <Button Content="Create" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
