<UserControl x:Class="GeorgiaERP.Desktop.Views.Compliance.ComplianceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">

    <DockPanel Margin="24,16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="RS.GE / Compliance" FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="RS.GE Status: " /><Run Text="{Binding RsGeStatus}" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
            <Button Content="Refresh" Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoadCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" />
        </DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="Waybills" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Waybills}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Waybills" />
            <RadioButton Content="Fiscal Documents" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=FiscalDocuments}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="FiscalDocuments" />
            <RadioButton Content="VAT Summary" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VatSummary}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="VatSummary" />
            <RadioButton Content="VAT Declarations" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VatDeclarations}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="VatDeclarations" />
            <RadioButton Content="Deadlines" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Deadlines}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="Deadlines" />
            <RadioButton Content="TIN Lookup" Style="{StaticResource NavButton}" Foreground="{StaticResource TextPrimaryBrush}"
                         IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TinLookup}"
                         Command="{Binding SwitchTabCommand}" CommandParameter="TinLookup" />
        </StackPanel>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" Foreground="{StaticResource PrimaryBrush}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

        <TextBlock DockPanel.Dock="Top" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

        <!-- Waybills -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Waybills}">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Create Waybill" Style="{StaticResource PrimaryButton}" Click="OnCreateWaybill" Margin="0,0,8,0" />
                <Button Content="Confirm" Style="{StaticResource SecondaryButton}" Command="{Binding ConfirmWaybillCommand}" Margin="0,0,8,0" />
                <Button Content="Close" Style="{StaticResource SecondaryButton}" Command="{Binding CloseWaybillCommand}" />
            </StackPanel>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding Waybills}" SelectedItem="{Binding SelectedWaybill}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}" RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Waybill #" Binding="{Binding WaybillNumber}" Width="130" />
                        <DataGridTextColumn Header="Type" Binding="{Binding WaybillType}" Width="80" />
                        <DataGridTextColumn Header="Buyer TIN" Binding="{Binding BuyerTin}" Width="100" />
                        <DataGridTextColumn Header="Buyer" Binding="{Binding BuyerName}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=d}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Fiscal Documents -->
        <Border Style="{StaticResource Card}" Padding="0"
                Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=FiscalDocuments}">
            <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding FiscalDocuments}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}" RowStyle="{StaticResource ModernDataGridRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding DocumentType}" Width="100" />
                    <DataGridTextColumn Header="Doc #" Binding="{Binding DocumentNumber}" Width="120" />
                    <DataGridTextColumn Header="Ref" Binding="{Binding InternalRef}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="RS.GE ID" Binding="{Binding RsGeId}" Width="100" />
                    <DataGridTextColumn Header="Deadline" Binding="{Binding SubmissionDeadline, StringFormat=d}" Width="100" />
                    <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedAt, StringFormat=g}" Width="140" />
                    <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="60" />
                    <DataGridTextColumn Header="Error" Binding="{Binding LastError}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- VAT Summary -->
        <Border Style="{StaticResource Card}" Padding="20"
                Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VatSummary}">
            <StackPanel MaxWidth="400">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Year" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding VatYear, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Month" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding VatMonth, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <Button Content="Load VAT Summary" Style="{StaticResource PrimaryButton}" Command="{Binding LoadCommand}" Margin="0,0,0,16" />

                <StackPanel Visibility="{Binding VatSummary, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                        <Run Text="Period: " /><Run Text="{Binding VatSummary.Period}" />
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"><Run Text="Output VAT: " /><Run Text="{Binding VatSummary.OutputVat, StringFormat=N2}" FontWeight="SemiBold" /></TextBlock>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"><Run Text="Input VAT: " /><Run Text="{Binding VatSummary.InputVat, StringFormat=N2}" FontWeight="SemiBold" /></TextBlock>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"><Run Text="Net VAT: " /><Run Text="{Binding VatSummary.NetVat, StringFormat=N2}" FontWeight="Bold" /></TextBlock>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"><Run Text="Status: " /><Run Text="{Binding VatSummary.Status}" /></TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- VAT Declarations -->
        <DockPanel Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VatDeclarations}">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="Year" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Style="{StaticResource ModernTextBox}" Width="70" Text="{Binding VatYear, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />
                <TextBlock Text="Month" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Style="{StaticResource ModernTextBox}" Width="50" Text="{Binding VatMonth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />
                <Button Content="+ Generate Declaration" Style="{StaticResource PrimaryButton}" Command="{Binding GenerateVatDeclarationCommand}" Margin="0,0,8,0" />
                <Button Content="Submit to RS.GE" Style="{StaticResource SecondaryButton}" Command="{Binding SubmitVatDeclarationCommand}" />
            </StackPanel>
            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding VatDeclarations}" SelectedItem="{Binding SelectedVatDeclaration}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}" RowStyle="{StaticResource ModernDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Period Start" Binding="{Binding PeriodStart, StringFormat=d}" Width="110" />
                        <DataGridTextColumn Header="Period End" Binding="{Binding PeriodEnd, StringFormat=d}" Width="110" />
                        <DataGridTextColumn Header="Output VAT" Binding="{Binding TotalOutputVat, StringFormat=N2}" Width="110" />
                        <DataGridTextColumn Header="Input VAT" Binding="{Binding TotalInputVat, StringFormat=N2}" Width="110" />
                        <DataGridTextColumn Header="Net VAT" Binding="{Binding NetVat, StringFormat=N2}" Width="110" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedAt, StringFormat=g}" Width="140" />
                        <DataGridTextColumn Header="RS.GE Ref" Binding="{Binding RsGeReference}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Deadlines -->
        <Border Style="{StaticResource Card}" Padding="16"
                Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Deadlines}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Visibility="{Binding Deadlines, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" Margin="0,0,16,0">
                        <Run Text="Overdue: " /><Run Text="{Binding Deadlines.OverdueCount}" />
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold">
                        <Run Text="Due Soon: " /><Run Text="{Binding Deadlines.DueSoonCount}" />
                    </TextBlock>
                </StackPanel>
                <DataGrid Style="{StaticResource ModernDataGrid}" ItemsSource="{Binding Deadlines.Documents}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}" RowStyle="{StaticResource ModernDataGridRow}" MaxHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100" />
                        <DataGridTextColumn Header="Ref" Binding="{Binding InternalRef}" Width="130" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Deadline" Binding="{Binding Deadline, StringFormat=d}" Width="100" />
                        <DataGridCheckBoxColumn Header="Overdue" Binding="{Binding IsOverdue}" Width="70" />
                        <DataGridTextColumn Header="Error" Binding="{Binding LastError}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- TIN Lookup -->
        <Border Style="{StaticResource Card}" Padding="20"
                Visibility="{Binding ActiveTab, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TinLookup}">
            <StackPanel MaxWidth="400">
                <TextBlock Text="TIN Lookup" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <TextBlock Text="Enter TIN (9-11 digits)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding TinInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <Button Content="Lookup" Style="{StaticResource PrimaryButton}" Command="{Binding LookupTinCommand}" Margin="0,0,0,16" />
                <TextBlock Text="{Binding TinResult}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"
                           Visibility="{Binding TinResult, Converter={StaticResource NullToCollapsedConverter}}" />
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
