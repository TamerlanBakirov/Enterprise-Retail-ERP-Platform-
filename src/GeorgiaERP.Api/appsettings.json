{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.Diagnostics.HealthChecks": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "GeorgiaERP.Infrastructure.RsGe": "Information",
        "GeorgiaERP.Infrastructure.Messaging": "Information",
        "GeorgiaERP.Api.Middleware": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "GeorgiaERP",
    "Audience": "GeorgiaERP.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Authentication": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "TotpEncryptionKey": ""
  },
  "Licensing": {
    "SigningKey": ""
  },
  "RsGe": {
    "WaybillServiceUrl": "https://services.rs.ge/WayBillService/WayBillService.asmx",
    "InvoiceServiceUrl": "https://webserv.rs.ge/specinvoices/SpecInvoicesService.asmx",
    "ServiceUser": "",
    "ServicePassword": "",
    "TimeoutSeconds": 30,
    "MaxRetryCount": 10,
    "Queue": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "VirtualHost": "/",
      "MaxRetryCount": 10,
      "RetryBaseDelaySeconds": 5,
      "RetryMaxDelaySeconds": 300
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "App": {
    "LatestVersion": "1.0.0",
    "DownloadUrl": "",
    "Sha256": ""
  },
  "RateLimiting": {
    "FixedPermitLimit": 100,
    "AuthPermitLimit": 20,
    "ReadPermitLimit": 200,
    "WritePermitLimit": 50,
    "ExportPermitLimit": 10
  },
  "Swagger": {
    "Enabled": false
  },
  "RefreshTokenCleanup": {
    "IntervalMinutes": 60,
    "RevokedRetentionDays": 7,
    "BatchSize": 1000
  },
  "Email": {
    "Smtp": {
      "Enabled": false,
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "noreply@georgiaerp.ge",
      "FromName": "Georgia ERP Platform",
      "TimeoutMs": 30000
    }
  },
  "LowStockAlert": {
    "IntervalMinutes": 30,
    "BatchSize": 500,
    "NotificationEmail": ""
  },
  "FileStorage": {
    "BasePath": "./uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".csv", ".txt"],
    "AllowedContentTypes": ["image/jpeg", "image/png", "image/gif", "image/webp", "image/bmp", "application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "text/csv", "text/plain"]
  },
  "HealthChecks": {
    "DiskSpaceThresholdMb": 1024
  },
  "HealthChecksUI": {
    "Enabled": false
  }
}
