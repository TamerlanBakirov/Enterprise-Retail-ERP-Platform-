{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=georgia_erp;Username=erp_user;Password=erp_password;Include Error Detail=true"
  },
  "Jwt": {
    "SecretKey": "CHANGE-THIS-TO-A-SECURE-KEY-AT-LEAST-64-CHARACTERS-LONG-FOR-HMAC-SHA256-SIGNING",
    "Issuer": "GeorgiaERP",
    "Audience": "GeorgiaERP.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
