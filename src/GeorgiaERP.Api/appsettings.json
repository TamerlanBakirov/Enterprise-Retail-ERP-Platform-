{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.Diagnostics.HealthChecks": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "GeorgiaERP.Infrastructure.RsGe": "Information",
        "GeorgiaERP.Infrastructure.Messaging": "Information",
        "GeorgiaERP.Api.Middleware": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=georgia_erp;Username=erp_user;Password=erp_dev_password;Include Error Detail=false;Maximum Pool Size=50;Minimum Pool Size=5;Connection Idle Lifetime=300",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=3000"
  },
  "Jwt": {
    "SecretKey": "CHANGE-THIS-TO-A-SECURE-KEY-AT-LEAST-64-CHARACTERS-LONG-FOR-HMAC-SHA256-SIGNING",
    "Issuer": "GeorgiaERP",
    "Audience": "GeorgiaERP.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Authentication": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "TotpEncryptionKey": "DEVELOPMENT-ONLY-TOTP-ENCRYPTION-KEY-CHANGE-IN-PRODUCTION"
  },
  "Licensing": {
    "SigningKey": "DEVELOPMENT-ONLY-LICENSE-SIGNING-KEY-CHANGE-IN-PRODUCTION-64-CHARS"
  },
  "RsGe": {
    "WaybillServiceUrl": "https://services.rs.ge/WayBillService/WayBillService.asmx",
    "InvoiceServiceUrl": "https://webserv.rs.ge/specinvoices/SpecInvoicesService.asmx",
    "ServiceUser": "",
    "ServicePassword": "",
    "TimeoutSeconds": 30,
    "MaxRetryCount": 10,
    "Queue": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "MaxRetryCount": 10,
      "RetryBaseDelaySeconds": 5,
      "RetryMaxDelaySeconds": 300
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "App": {
    "LatestVersion": "1.0.0",
    "DownloadUrl": "",
    "Sha256": ""
  },
  "RateLimiting": {
    "FixedPermitLimit": 100,
    "AuthPermitLimit": 10
  },
  "Swagger": {
    "Enabled": false
  },
  "RefreshTokenCleanup": {
    "IntervalMinutes": 60,
    "RevokedRetentionDays": 7,
    "BatchSize": 1000
  },
  "Email": {
    "Smtp": {
      "Enabled": false,
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "noreply@georgiaerp.ge",
      "FromName": "Georgia ERP Platform",
      "TimeoutMs": 30000
    }
  },
  "LowStockAlert": {
    "IntervalMinutes": 30,
    "BatchSize": 500,
    "NotificationEmail": ""
  },
  "HealthChecksUI": {
    "Enabled": false
  }
}
