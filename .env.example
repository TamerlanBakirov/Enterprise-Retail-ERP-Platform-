# =============================================================================
# Georgia ERP - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the .env file to version control.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=<STRONG_PASSWORD_HERE>
POSTGRES_DB=georgia_erp

# ---- RabbitMQ ----
RABBITMQ_USER=erp_user
RABBITMQ_PASSWORD=<STRONG_PASSWORD_HERE>

# ---- Redis ----
REDIS_PASSWORD=<STRONG_PASSWORD_HERE>

# ---- JWT Authentication ----
# Must be at least 64 characters for HMAC-SHA256
JWT_SECRET_KEY=<GENERATE_WITH: openssl rand -base64 64>

# ---- Licensing ----
LICENSE_SIGNING_KEY=<GENERATE_WITH: openssl rand -base64 64>

# ---- TOTP / 2FA Encryption ----
TOTP_ENCRYPTION_KEY=<GENERATE_WITH: openssl rand -base64 32>

# ---- Grafana (monitoring) ----
GRAFANA_ADMIN_PASSWORD=<STRONG_PASSWORD_HERE>

# ---- RS.GE Integration (Georgia Tax Authority) ----
RSGE_USER=
RSGE_PASSWORD=

# ---- CORS / Frontend ----
FRONTEND_ORIGIN=https://your-domain.example.com

# ---- Allowed Hosts ----
ALLOWED_HOSTS=your-domain.example.com

# ---- App Update Info ----
APP_LATEST_VERSION=1.0.0
APP_DOWNLOAD_URL=
APP_UPDATE_SHA256=

# ---- Docker Image Registry (for CI/CD) ----
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=your-org/georgia-erp
